# --- Database ---
# Local dev: a mongod on the default port. Railway injects MONGO_URL for its
# MongoDB service, which the app picks up automatically.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=pablo_fp

# --- Security ---
# Sign JWTs for the admin panel. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Admin panel credentials (seeded/updated on every boot).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Comma-separated origins allowed to call this API (your Vercel URL).
CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app

# Staff logins used on the form itself. Format: user:password,user:password
# Defaults to the three existing users if left unset.
STAFF_CREDENTIALS=irfan:irfan@2026,vinod:vinod@2026,tushar:tushar@2026

# --- Email (the PDF is mailed to the distribution list after each submit) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@pablotheartcafe.com
SMTP_PASS=
MAIL_FROM="Pablo Function Prospectus <info@pablotheartcafe.com>"

# Comma-separated recipients. Defaults to the cpgh.in list if unset.
NOTIFY_EMAILS=rm.pablo@cpgh.in,chef.ufo@cpgh.in,accounts.ufo@cpgh.in,fo.units1@cpgh.in,angadh.arora@cpgh.in,arjun.arora@cpgh.in,fnbcontroller.nagpur@cpgh.in,digital@cpgh.in
